# Google Books API keys — required for book metadata search.
# Create two separate keys at https://console.cloud.google.com/ → APIs & Services → Credentials.
# Enable the "Books API" for your project first.
#
# ANDROID key → set "Android apps" restriction:
#   - Add your package name (e.g. com.yourname.bookmark)
#   - Add SHA-1 fingerprint for debug builds:
#       cd android && ./gradlew signingReport
#       Copy the SHA1 value from the "debug" variant.
#   - Add a second entry for your release SHA-1 when building for production.
#
# IOS key → set "iOS apps" restriction:
#   - Add your bundle ID (e.g. com.yourname.bookmark), set in app.json as ios.bundleIdentifier.
GOOGLE_BOOKS_API_KEY_ANDROID=your_android_api_key_here
GOOGLE_BOOKS_API_KEY_IOS=your_ios_api_key_here

# SHA-1 signing certificate fingerprint for the Android API key restriction.
# Format: AA:BB:CC:DD:EE:FF:... (colon-separated hex, as printed by keytool / gradlew signingReport).
# Use your debug SHA-1 for development. For production, use your release keystore SHA-1.
GOOGLE_BOOKS_ANDROID_CERT=AA:BB:CC:DD:EE:FF:00:11:22:33:44:55:66:77:88:99:AA:BB:CC:DD
